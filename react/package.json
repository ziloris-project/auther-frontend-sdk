{
  "name": "@auther-sdk/react",
  "version": "1.2.1",
  "description": "Official React bindings for Auther — drop-in AutherProvider with built-in session management and proactive token refresh.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/ziloris-project/auther-frontend-sdk/tree/main/react#readme",
  "bugs": {
    "url": "https://github.com/ziloris-project/auther-frontend-sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ziloris-project/auther-frontend-sdk.git",
    "directory": "react"
  },
  "author": {
    "name": "Ziloris",
    "url": "https://ziloris.com"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "auther",
    "auth",
    "react",
    "provider",
    "hook",
    "session",
    "token-refresh"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@auther-sdk/frontend": "workspace:^"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "react": "^19.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
